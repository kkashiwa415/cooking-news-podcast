# Copy this file to `.env` and fill in your real key.
# Do NOT commit .env to git.

ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Optional - pick an Edge TTS voice. Default: en-US-AriaNeural (warm female).
# Run `edge-tts --list-voices` to see all options (hundreds of voices, many languages).
# Good news-anchor picks:
#   en-US-AriaNeural                   - warm, professional female  (default)
#   en-US-JennyNeural                  - news-anchor female
#   en-US-GuyNeural                    - friendly male
#   en-US-AndrewMultilingualNeural     - rich male narrator
#   en-GB-SoniaNeural                  - British female
# EDGE_TTS_VOICE=en-US-AriaNeural
